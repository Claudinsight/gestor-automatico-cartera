# ═══════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL GESTOR AUTOMÁTICO DE CARTERA
# ═══════════════════════════════════════════════════════════════════
# Copia este archivo a `.env` y completa los valores reales.
# NUNCA subas el archivo .env al repositorio (ya está en .gitignore).
# ═══════════════════════════════════════════════════════════════════

# ─── API de Claude (Anthropic) ─────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZA-CON-TU-CLAVE-REAL

# Modelo a utilizar (claude-sonnet-4-5, claude-opus-4-6, claude-haiku-4-5)
CLAUDE_MODEL=claude-sonnet-4-5

# Máximo de tokens en la respuesta de Claude
CLAUDE_MAX_TOKENS=2000

# ─── Servidor Flask ────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ─── Parámetros de la cartera ──────────────────────────────────────
# Capital total disponible en euros
CAPITAL=20000

# Peso máximo por posición (%)
MAX_POSITION_PCT=25

# Porcentaje de stop-loss aplicado a cada posición
STOP_LOSS_PCT=8

# Número mínimo de sectores para diversificar
MIN_SECTORS=4
